#!/usr/bin/env -S deno run --allow-read --allow-run --allow-env

import { readAll } from "jsr:@std/io@0.224/read-all";

type UsageMetric = {
  used_percentage?: number;
  resets_at?: number;
};

type ContextWindowUsage = {
  input_tokens?: number;
  output_tokens?: number;
  cache_creation_input_tokens?: number;
  cache_read_input_tokens?: number;
};

type RateLimitHealth = {
  budgetLeftPct: number;
  timeLeftPct: number;
  remainingDuration: string;
  resetAtLabel: string;
  statusLabel: string;
  statusIcon: string;
  statusColor: Rgb;
};

type StatusLineInput = {
  model?: {
    display_name?: string;
  };
  effort?: {
    level?: string;
  };
  workspace?: {
    current_dir?: string;
  };
  context_window?: UsageMetric & {
    context_window_size?: number;
    current_usage?: ContextWindowUsage | null;
  };
  rate_limits?: {
    five_hour?: UsageMetric;
    seven_day?: UsageMetric;
  };
};

const RESET = "\x1b[0m";
const BAR_BLOCKS = " ▏▎▍▌▋▊▉█";
const FIVE_HOUR_WINDOW_MS = 5 * 60 * 60 * 1000;
const SEVEN_DAY_WINDOW_MS = 7 * 24 * 60 * 60 * 1000;

type Rgb = readonly [number, number, number];

const PALETTE = {
  green: [166, 227, 161] as Rgb,
  yellow: [249, 226, 175] as Rgb,
  red: [243, 139, 168] as Rgb,
  blue: [137, 180, 250] as Rgb,
  lavender: [180, 190, 254] as Rgb,
  peach: [250, 179, 135] as Rgb,
  sapphire: [116, 199, 236] as Rgb,
  subtext1: [186, 194, 222] as Rgb,
  subtext0: [166, 173, 200] as Rgb,
  overlay0: [108, 112, 134] as Rgb,
};

async function getGitBranch(): Promise<string> {
  try {
    const isGitRepo = new Deno.Command("git", {
      args: ["rev-parse"],
      stdout: "null",
      stderr: "null",
    });
    const { success } = await isGitRepo.output();

    if (!success) {
      return "";
    }

    const branchCmd = new Deno.Command("git", {
      args: ["branch", "--show-current"],
      stdout: "piped",
      stderr: "null",
    });
    const { stdout } = await branchCmd.output();
    const branch = new TextDecoder().decode(stdout).trim();

    if (branch) {
      return branch;
    }

    const hashCmd = new Deno.Command("git", {
      args: ["rev-parse", "--short", "HEAD"],
      stdout: "piped",
      stderr: "null",
    });
    const { stdout: hashStdout } = await hashCmd.output();
    const commitHash = new TextDecoder().decode(hashStdout).trim();

    if (commitHash) {
      return `HEAD (${commitHash})`;
    }
  } catch {
  }

  return "";
}

function clampPercentage(value: number): number {
  return Math.min(Math.max(value, 0), 100);
}

function rgb(color: Rgb): string {
  return `\x1b[38;2;${color[0]};${color[1]};${color[2]}m`;
}

function mixColor(from: Rgb, to: Rgb, ratio: number): Rgb {
  const safeRatio = Math.min(Math.max(ratio, 0), 1);
  return [
    Math.round(from[0] + (to[0] - from[0]) * safeRatio),
    Math.round(from[1] + (to[1] - from[1]) * safeRatio),
    Math.round(from[2] + (to[2] - from[2]) * safeRatio),
  ];
}

function gradient(pct: number): string {
  const safePct = clampPercentage(pct);

  if (safePct <= 60) {
    return rgb(mixColor(PALETTE.green, PALETTE.yellow, safePct / 60));
  }

  return rgb(mixColor(PALETTE.yellow, PALETTE.red, (safePct - 60) / 40));
}

function remainingBar(remainingPct: number, color: Rgb, width = 10): string {
  const safeRemaining = clampPercentage(remainingPct);
  const filled = (safeRemaining * width) / 100;
  const fullBlocks = Math.floor(filled);
  const partialBlock = Math.floor((filled - fullBlocks) * 8);

  let bar = "";
  for (let i = 0; i < width; i++) {
    if (i < fullBlocks) {
      bar += `${rgb(color)}█${RESET}`;
    } else if (i === fullBlocks && partialBlock > 0) {
      bar += `${rgb(color)}${BAR_BLOCKS[partialBlock]}${RESET}`;
    } else {
      bar += `${rgb(PALETTE.overlay0)}░${RESET}`;
    }
  }

  return bar;
}

function formatApproxTokens(totalTokens: number): string {
  if (totalTokens >= 1000000) {
    return `${(totalTokens / 1000000).toFixed(1).replace(/\.0$/, "")}M`;
  }
  if (totalTokens >= 1000) {
    return `${(totalTokens / 1000).toFixed(1).replace(/\.0$/, "")}K`;
  }

  return `${totalTokens}`;
}

function formatTokenRatio(tokenCount: number, totalTokens: number): string {
  return `${formatApproxTokens(tokenCount)} / ${formatApproxTokens(totalTokens)}`;
}

function formatDuration(remainingMs: number): string {
  const safeMs = Math.max(remainingMs, 0);
  const totalMinutes = Math.ceil(safeMs / 60000);
  const days = Math.floor(totalMinutes / (24 * 60));
  const hours = Math.floor((totalMinutes % (24 * 60)) / 60);
  const minutes = totalMinutes % 60;

  if (days > 0) {
    return hours > 0 ? `${days}d${hours}h` : `${days}d`;
  }
  if (hours > 0) {
    return minutes > 0 ? `${hours}h${minutes}m` : `${hours}h`;
  }

  return `${minutes}m`;
}

const WEEKDAY_LABELS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

function formatResetAt(resetAtMs: number): string {
  const reset = new Date(resetAtMs);
  const now = new Date();
  const time = `${String(reset.getHours()).padStart(2, "0")}:${String(reset.getMinutes()).padStart(2, "0")}`;
  const sameDay = reset.getFullYear() === now.getFullYear() &&
    reset.getMonth() === now.getMonth() &&
    reset.getDate() === now.getDate();

  if (sameDay) {
    return time;
  }

  return `${reset.getMonth() + 1}/${reset.getDate()} ${WEEKDAY_LABELS[reset.getDay()]} ${time}`;
}

function formatBudgetVsTimeDelta(budgetLeftPct: number, timeLeftPct: number): string {
  const delta = Math.round(budgetLeftPct - timeLeftPct);
  const prefix = delta > 0 ? "+" : "";
  const value = `${prefix}${delta}pt`.padStart(5);

  return value;
}

function formatPercent(value: number): string {
  return `${Math.round(value).toString().padStart(3)}%`;
}

function getContextInputTokens(currentUsage?: ContextWindowUsage | null): number | null {
  if (!currentUsage) {
    return null;
  }

  return (currentUsage.input_tokens || 0) +
    (currentUsage.cache_creation_input_tokens || 0) +
    (currentUsage.cache_read_input_tokens || 0);
}

function getRateLimitHealth(usedPct?: number, resetsAt?: number, windowMs?: number): RateLimitHealth | null {
  if (
    usedPct === undefined ||
    resetsAt === undefined ||
    windowMs === undefined ||
    Number.isNaN(usedPct) ||
    Number.isNaN(resetsAt)
  ) {
    return null;
  }

  const budgetLeftPct = clampPercentage(100 - usedPct);
  const resetAtMs = resetsAt * 1000;
  const remainingMs = Math.max(resetAtMs - Date.now(), 0);
  const timeLeftPct = clampPercentage((Math.min(remainingMs, windowMs) / windowMs) * 100);
  const slack = budgetLeftPct - timeLeftPct;
  const base = {
    budgetLeftPct,
    timeLeftPct,
    remainingDuration: formatDuration(remainingMs),
    resetAtLabel: formatResetAt(resetAtMs),
  };

  if (slack >= 15) {
    return { ...base, statusLabel: "safe", statusIcon: "✓", statusColor: PALETTE.green };
  }
  if (slack >= 0) {
    return { ...base, statusLabel: "on pace", statusIcon: "◐", statusColor: PALETTE.yellow };
  }
  if (slack >= -15) {
    return { ...base, statusLabel: "tight", statusIcon: "⚠", statusColor: PALETTE.peach };
  }

  return { ...base, statusLabel: "critical", statusIcon: "✕", statusColor: PALETTE.red };
}

function formatRateLimitMetric(label: string, health: RateLimitHealth | null): string | null {
  if (!health) {
    return null;
  }

  const budgetField = `●${formatPercent(health.budgetLeftPct)}`;
  const timeField = `⌛${formatPercent(health.timeLeftPct)}`;
  const delta = Math.round(health.budgetLeftPct - health.timeLeftPct);
  const deltaField = formatBudgetVsTimeDelta(health.budgetLeftPct, health.timeLeftPct);
  const deltaColor = delta < 0 ? health.statusColor : PALETTE.green;
  const resetField = `↺ ${health.remainingDuration}`.padEnd(8);

  return `${rgb(PALETTE.subtext1)}${label}${RESET} ${remainingBar(health.budgetLeftPct, health.statusColor)} ${
    rgb(health.statusColor)
  }${budgetField}${RESET} ${rgb(PALETTE.overlay0)}|${RESET} ${rgb(PALETTE.subtext0)}${timeField}${RESET} ${
    rgb(PALETTE.overlay0)
  }|${RESET} ${rgb(deltaColor)}${deltaField}${RESET} ${rgb(PALETTE.overlay0)}|${RESET} ${
    rgb(PALETTE.sapphire)
  }${resetField}${RESET} ${rgb(PALETTE.overlay0)}→${RESET} ${rgb(PALETTE.subtext0)}${health.resetAtLabel}${RESET}`;
}

function formatContextSummary(pct?: number, meta?: string | null): string | null {
  if (pct === undefined || Number.isNaN(pct) || !meta) {
    return null;
  }

  const rounded = Math.round(clampPercentage(pct));
  return `${rgb(PALETTE.overlay0)}${RESET}  ${rgb(PALETTE.subtext0)}${meta}${RESET} ${
    gradient(pct)
  }${rounded}%${RESET}`;
}

function formatFirstLineItem(icon: string, text: string, color: Rgb): string {
  return `${rgb(PALETTE.overlay0)}${icon}${RESET}  ${rgb(color)}${text}${RESET}`;
}

function formatEffortLevel(level?: string): string | null {
  const normalized = level?.trim();

  if (!normalized) {
    return null;
  }

  return normalized === "xhigh" ? "x-high" : normalized;
}

function formatModelItem(modelDisplay: string, effortLevel?: string): string {
  const model = `${rgb(PALETTE.lavender)}${modelDisplay}${RESET}`;
  const effortLevelDisplay = formatEffortLevel(effortLevel);

  if (!effortLevelDisplay) {
    return `${rgb(PALETTE.overlay0)}󰚩${RESET}  ${model}`;
  }

  const effort = `${rgb(PALETTE.overlay0)}·${RESET} ${rgb(PALETTE.peach)}󰢚 ${effortLevelDisplay}${RESET}`;
  return `${rgb(PALETTE.overlay0)}󰚩${RESET}  ${model} ${effort}`;
}

async function main() {
  const stdin = await readAll(Deno.stdin);
  const input = JSON.parse(new TextDecoder().decode(stdin)) as StatusLineInput;

  const modelDisplay = input.model?.display_name || "Unknown";
  const effortLevel = input.effort?.level;
  const currentDir = input.workspace?.current_dir || ".";
  const dirName = currentDir.split("/").pop() || currentDir;

  const gitBranch = await getGitBranch();
  const contextInputTokens = getContextInputTokens(input.context_window?.current_usage);
  const contextWindowSize = input.context_window?.context_window_size;
  const ctxMeta = contextInputTokens != null && contextWindowSize != null
    ? formatTokenRatio(contextInputTokens, contextWindowSize)
    : null;
  const ctxSummary = formatContextSummary(input.context_window?.used_percentage, ctxMeta);
  const fiveHourHealth = getRateLimitHealth(
    input.rate_limits?.five_hour?.used_percentage,
    input.rate_limits?.five_hour?.resets_at,
    FIVE_HOUR_WINDOW_MS,
  );
  const sevenDayHealth = getRateLimitHealth(
    input.rate_limits?.seven_day?.used_percentage,
    input.rate_limits?.seven_day?.resets_at,
    SEVEN_DAY_WINDOW_MS,
  );

  const firstLineParts = [
    formatModelItem(modelDisplay, effortLevel),
    formatFirstLineItem("", dirName, PALETTE.blue),
    ...(gitBranch ? [formatFirstLineItem("󰘬", gitBranch, PALETTE.green)] : []),
    ...(ctxSummary ? [ctxSummary] : []),
  ];

  const usageParts = [
    formatRateLimitMetric("5h", fiveHourHealth),
    formatRateLimitMetric("7d", sevenDayHealth),
  ].filter((value): value is string => value !== null);

  if (usageParts.length === 0) {
    console.log(firstLineParts.join(` ${rgb(PALETTE.overlay0)}|${RESET} `));
    return;
  }

  const rateLimitLines = usageParts.map((line, index) => {
    const guide = index === usageParts.length - 1 ? "└" : "├";
    return `${rgb(PALETTE.overlay0)}${guide}${RESET} ${line}`;
  });

  console.log(`${firstLineParts.join(` ${rgb(PALETTE.overlay0)}|${RESET} `)}\n${rateLimitLines.join("\n")}`);
}

if (import.meta.main) {
  main().catch((error) => {
    console.error("Error:", error);
    Deno.exit(1);
  });
}
