{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^startup$|^resume$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/dotfiles/bin/codex-session-start-agent-note.js\"",
            "timeoutSec": 3,
            "statusMessage": "AGENT_NOTE_DIR を読み込み中"
          }
        ]
      },
      {
        "matcher": "^startup$|^resume$|^clear$",
        "hooks": [
          {
            "type": "command",
            "command": "vt hook codex SessionStart"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex PreToolUse" },
          { "type": "command", "command": "vt hook codex PreToolUse" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex PostToolUse" },
          { "type": "command", "command": "vt hook codex PostToolUse" }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex PermissionRequest" },
          { "type": "command", "command": "vt hook codex PermissionRequest" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex Stop" },
          { "type": "command", "command": "vt hook codex Stop" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex UserPromptSubmit" },
          { "type": "command", "command": "vt hook codex UserPromptSubmit" }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex SubagentStart" },
          { "type": "command", "command": "vt hook codex SubagentStart" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "vde-monitor-hook codex SubagentStop" },
          { "type": "command", "command": "vt hook codex SubagentStop" }
        ]
      }
    ]
  }
}
